# Copy to deploy/fly/.env.local and fill in.
# .env.local matches the .env.* rule in .gitignore — never committed.
# Bootstrap reads this file and pushes secrets to Fly via `flyctl secrets import`.
# After editing, re-run deploy/fly/bootstrap.sh to push the updated values.

# --- Required for any deploy ----------------------------------------------

# Fly region. Pick one close to your DB. Neon us-east-1 ↔ Fly iad.
REGION=iad

# CloudAMQP / RabbitMQ. Use the amqps:// (TLS) URI.
RABBITMQ_URL=amqps://USER:PASS@host.cloudamqp.com/VHOST

# Upstash / Redis. Use the rediss:// (TLS) URI.
REDIS_URL=rediss://default:TOKEN@host.upstash.io:6379

# Neon Postgres — single project, multiple databases.
# POSTGRES_BASE: scheme://user:pass@host (no /dbname, no ?query)
# POSTGRES_QUERY: leading "?" with all params (Neon: ?sslmode=require&channel_binding=require)
# Bootstrap composes per service: ${POSTGRES_BASE}/<dbname>${POSTGRES_QUERY}
POSTGRES_BASE=postgres://default:PASS@ep-xxx-pooler.us-east-1.aws.neon.tech
POSTGRES_QUERY=?sslmode=require&channel_binding=require

# --- BFF CORS -------------------------------------------------------------
# Optional. The BFF defaults to allowing http://localhost:4321 (Astro dev
# server) + https://ritualworks.pages.dev + https://portfolio-showcase.pages.dev
# (canonical Cloudflare Pages URLs). Set this to add a custom domain
# (e.g. https://ritualworks.com). Leave blank to keep the defaults.
PORTFOLIO_SITE_URL=

# --- Identity service -----------------------------------------------------

# RSA-2048 PEM private key, base64-encoded so it fits on one line.
# Leave blank — bootstrap.sh auto-generates one and writes it back here on
# first run, then reuses it on subsequent runs (so issued tokens stay valid
# across re-deploys).
JWT_SIGNING_KEY_PEM=
JWT_KEY_ID=fly-1

# Issuer/Audience have defaults in appsettings.json. Override only if your
# public BFF URL differs from the convention.
JWT_ISSUER=
JWT_AUDIENCE=

# OAuth providers — leave blank to skip. With the conditional-registration
# fix in Identity.Infrastructure, blank values no longer crash startup.
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_MICROSOFT_CLIENT_ID=
OAUTH_MICROSOFT_CLIENT_SECRET=
OAUTH_FACEBOOK_APP_ID=
OAUTH_FACEBOOK_APP_SECRET=

# --- Payments service -----------------------------------------------------

STRIPE_WEBHOOK_SECRET=

# --- Content service ------------------------------------------------------
# Default deploy SKIPS content-svc (no S3-compatible storage configured).
# Set DEPLOY_CONTENT=true and provide MinIO/S3 credentials to include it.

DEPLOY_CONTENT=false
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=true
CLAMAV_REST_URL=

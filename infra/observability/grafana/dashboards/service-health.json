{
  "uid": "service-health",
  "title": "Service Health",
  "description": "Overview of all Haworks platform services - uptime, request rates, error rates, latency",
  "tags": ["haworks", "platform"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "15s",
  "time": { "from": "now-1h", "to": "now" },
  "templating": {
    "list": [
      {
        "name": "service",
        "type": "query",
        "datasource": "Prometheus",
        "query": "label_values(up{job=\"haworks-services\"}, service_name)",
        "includeAll": true,
        "multi": true,
        "current": { "text": "All", "value": "$__all" }
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "title": "Service Up/Down",
      "type": "stat",
      "gridPos": { "h": 4, "w": 24, "x": 0, "y": 0 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "up{job=\"haworks-services\", service_name=~\"$service\"}",
          "legendFormat": "{{ service_name }} ({{ instance }})"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ],
          "thresholds": { "steps": [{ "value": 0, "color": "red" }, { "value": 1, "color": "green" }] }
        }
      }
    },
    {
      "id": 2,
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[1m])) by (service_name)",
          "legendFormat": "{{ service_name }}"
        }
      ]
    },
    {
      "id": 3,
      "title": "Error Rate (5xx %)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "sum(rate(http_server_request_duration_seconds_count{http_response_status_code=~\"5..\", service_name=~\"$service\"}[5m])) by (service_name) / sum(rate(http_server_request_duration_seconds_count{service_name=~\"$service\"}[5m])) by (service_name) * 100",
          "legendFormat": "{{ service_name }}"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "max": 100 } }
    },
    {
      "id": 4,
      "title": "P99 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, sum(rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])) by (le, service_name))",
          "legendFormat": "{{ service_name }} p99"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 5,
      "title": "P50 Latency",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "histogram_quantile(0.50, sum(rate(http_server_request_duration_seconds_bucket{service_name=~\"$service\"}[5m])) by (le, service_name))",
          "legendFormat": "{{ service_name }} p50"
        }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "id": 6,
      "title": "GC Collections (Gen2)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "rate(dotnet_gc_collections_total{generation=\"gen2\", service_name=~\"$service\"}[5m])",
          "legendFormat": "{{ service_name }}"
        }
      ]
    },
    {
      "id": 7,
      "title": "Thread Pool Queue Length",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "datasource": "Prometheus",
      "targets": [
        {
          "expr": "dotnet_thread_pool_queue_length{service_name=~\"$service\"}",
          "legendFormat": "{{ service_name }}"
        }
      ]
    }
  ]
}

<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Haworks.Localization.Integration</RootNamespace>
    <AssemblyName>Haworks.Localization.Integration</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Testcontainers.PostgreSql" />
    <PackageReference Include="MassTransit.TestFramework" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/Localization/Localization.Api/Localization.Api.csproj" />
    <ProjectReference Include="../../../src/BuildingBlocks.Testing/Haworks.BuildingBlocks.Testing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- Per-assembly Testcontainers / Docker Desktop fixes. See
         src/BuildingBlocks.Testing/TestModuleInitializer.cs for the rationale.
         Linked rather than referenced because [ModuleInitializer] only fires
         for the assembly the attribute is compiled into. -->
    <Compile Include="../../../src/BuildingBlocks.Testing/TestModuleInitializer.cs"
             Link="TestModuleInitializer.cs" />
  </ItemGroup>

</Project>

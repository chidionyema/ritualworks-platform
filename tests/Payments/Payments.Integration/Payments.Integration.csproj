    <PackageReference Include="Moq" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" />
    <PackageReference Include="Testcontainers.PostgreSql" />
    <PackageReference Include="MassTransit.TestFramework" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/Payments/Payments.Api/Payments.Api.csproj" />
    <ProjectReference Include="../../../src/BuildingBlocks.Testing/Haworks.BuildingBlocks.Testing.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="../../../src/BuildingBlocks.Testing/TestModuleInitializer.cs"
             Link="TestModuleInitializer.cs" />
  </ItemGroup>


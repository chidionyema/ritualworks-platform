<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Haworks.Pricing.Unit</RootNamespace>
    <AssemblyName>Haworks.Pricing.Unit</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
    <NoWarn>$(NoWarn);AsyncFixer01</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Moq" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/Pricing/Pricing.Domain/Pricing.Domain.csproj" />
    <ProjectReference Include="../../../src/Pricing/Pricing.Application/Pricing.Application.csproj" />
    <ProjectReference Include="../../../src/Pricing/Pricing.Infrastructure/Pricing.Infrastructure.csproj" />
  </ItemGroup>

</Project>

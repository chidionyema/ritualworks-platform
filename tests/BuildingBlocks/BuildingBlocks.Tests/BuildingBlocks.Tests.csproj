<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Haworks.BuildingBlocks.Tests</RootNamespace>
    <AssemblyName>Haworks.BuildingBlocks.Tests</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Microsoft.NET.Test.Sdk" />
    <PackageReference Include="xunit" />
    <PackageReference Include="xunit.runner.visualstudio" />
    <PackageReference Include="FluentAssertions" />
    <PackageReference Include="Moq" />
    <!-- Testcontainers (generic ContainerBuilder) for Vault dev-mode integration -->
    <PackageReference Include="Testcontainers" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/BuildingBlocks/Haworks.BuildingBlocks.csproj" />
    <ProjectReference Include="../../../src/BuildingBlocks.Testing/Haworks.BuildingBlocks.Testing.csproj" />
  </ItemGroup>

  <!-- Compile TestModuleInitializer.cs directly into this assembly so the
       [ModuleInitializer] fires here. ProjectReference alone wouldn't run
       it (initializers fire only for their own assembly). Same pattern as
       every other *.Integration test project; see TestModuleInitializer.cs
       for the macOS Docker / Ryuk socket-bind workarounds it installs. -->
  <ItemGroup>
    <Compile Include="../../../src/BuildingBlocks.Testing/TestModuleInitializer.cs"
             Link="TestModuleInitializer.cs" />
  </ItemGroup>

</Project>

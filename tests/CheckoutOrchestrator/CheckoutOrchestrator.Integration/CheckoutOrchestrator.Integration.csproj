<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <RootNamespace>Haworks.CheckoutOrchestrator.Integration</RootNamespace>
    <AssemblyName>Haworks.CheckoutOrchestrator.Integration</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>
    <AnalysisLevel>none</AnalysisLevel>
    <TreatWarningsAsErrors>false</TreatWarningsAsErrors>
  </PropertyGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <PackageReference Include="Microsoft.NET.Test.Sdk" Version="17.12.0" />
    <PackageReference Include="xunit" Version="2.9.2" />
    <PackageReference Include="xunit.runner.visualstudio" Version="2.8.2" />
    <PackageReference Include="FluentAssertions" Version="7.0.0" />
    <PackageReference Include="Microsoft.AspNetCore.Mvc.Testing" Version="9.0.0" />
    <PackageReference Include="Testcontainers.PostgreSql" Version="4.0.0" />
    <PackageReference Include="MassTransit.TestFramework" Version="8.3.4" />
    <PackageReference Include="MassTransit.EntityFrameworkCore" Version="8.3.4" />
  </ItemGroup>

  <ItemGroup>
    <ProjectReference Include="../../../src/CheckoutOrchestrator/CheckoutOrchestrator.Api/CheckoutOrchestrator.Api.csproj" />
    <ProjectReference Include="../../../src/BuildingBlocks.Testing/Haworks.BuildingBlocks.Testing.csproj" />
    <!-- Saga compensation chaos test wires the catalog StockReleaseRequestedConsumer
         in-process so the test can prove the full compensation chain in one
         harness. The other CheckoutOrchestrator.Integration tests don't touch
         Catalog at all, but the cross-reference is OK at test-time per the
         monorepo boundary rules (tests are end-to-end consumers of all
         service contracts). -->
    <ProjectReference Include="../../../src/Catalog/Catalog.Application/Catalog.Application.csproj" />
    <ProjectReference Include="../../../src/Catalog/Catalog.Infrastructure/Catalog.Infrastructure.csproj" />
  </ItemGroup>

  <ItemGroup>
    <Compile Include="../../../src/BuildingBlocks.Testing/TestModuleInitializer.cs"
             Link="TestModuleInitializer.cs" />
  </ItemGroup>

</Project>

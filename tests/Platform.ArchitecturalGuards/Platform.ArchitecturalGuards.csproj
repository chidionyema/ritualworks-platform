    <PackageReference Include="NetArchTest.Rules" Version="1.3.2" />
  </ItemGroup>

  <!-- Reference all service assemblies for NetArchTest reflection-based rules -->
  <ItemGroup>
    <ProjectReference Include="../../src/Payments/Payments.Domain/Payments.Domain.csproj" />
    <ProjectReference Include="../../src/Payments/Payments.Application/Payments.Application.csproj" />
    <ProjectReference Include="../../src/Payments/Payments.Infrastructure/Payments.Infrastructure.csproj" />
    <ProjectReference Include="../../src/Payouts/Payouts.Domain/Payouts.Domain.csproj" />
    <ProjectReference Include="../../src/Payouts/Payouts.Application/Payouts.Application.csproj" />
    <ProjectReference Include="../../src/Payouts/Payouts.Infrastructure/Payouts.Infrastructure.csproj" />
    <ProjectReference Include="../../src/BuildingBlocks/Haworks.BuildingBlocks.csproj" />
  </ItemGroup>

</Project>

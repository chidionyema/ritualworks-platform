  <PropertyGroup>
    <RootNamespace>Haworks.Platform.ArchitecturalGuards</RootNamespace>
    <AssemblyName>Haworks.Platform.ArchitecturalGuards</AssemblyName>
    <IsPackable>false</IsPackable>
    <IsTestProject>true</IsTestProject>

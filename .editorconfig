root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
indent_style = space
trim_trailing_whitespace = true

[*.{cs,csx,vb,vbx}]
indent_size = 4

[*.{json,yml,yaml,md,sh}]
indent_size = 2

[*.{cs}]
# Naming: see .claude/rules/code-quality.md (lifted from monolith reference)
dotnet_naming_rule.private_fields_should_have_underscore_prefix.severity = error
dotnet_naming_rule.private_fields_should_have_underscore_prefix.symbols = private_fields
dotnet_naming_rule.private_fields_should_have_underscore_prefix.style = underscore_prefix

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
dotnet_naming_symbols.private_fields.required_modifiers =

dotnet_naming_style.underscore_prefix.required_prefix = _
dotnet_naming_style.underscore_prefix.capitalization = camel_case

# Async methods must end in Async
dotnet_naming_rule.async_methods_end_in_async.severity = error
dotnet_naming_rule.async_methods_end_in_async.symbols = async_methods
dotnet_naming_rule.async_methods_end_in_async.style = end_in_async

dotnet_naming_symbols.async_methods.applicable_kinds = method
dotnet_naming_symbols.async_methods.required_modifiers = async

dotnet_naming_style.end_in_async.required_suffix = Async
dotnet_naming_style.end_in_async.capitalization = pascal_case

# ═══════════════════════════════════════════════════════════════════════
# ROSLYN ANALYZER CONFIGURATION
# Rules enforced as errors (build-blocking) vs suggestions (IDE hints)
# ═══════════════════════════════════════════════════════════════════════

# ── SonarAnalyzer (S-rules) ──────────────────────────────────────────
# Critical rules kept as error. Noisy/cosmetic rules suppressed.
dotnet_diagnostic.S1135.severity = suggestion   # Track uses of "TODO"
dotnet_diagnostic.S3459.severity = none         # Unassigned members — false positive on init properties
dotnet_diagnostic.S3604.severity = none         # Member initializer redundant — clarity > pedantry
dotnet_diagnostic.S6966.severity = suggestion   # Awaitable method in non-async — too aggressive
dotnet_diagnostic.S6968.severity = none         # Prefer async overload — already async everywhere
dotnet_diagnostic.S2094.severity = none         # Empty class — marker classes are OK
dotnet_diagnostic.S1118.severity = none         # Utility class non-instantiable — overkill
dotnet_diagnostic.S3218.severity = none         # Field shadows outer member — common in nested Error types
dotnet_diagnostic.S927.severity = none          # Parameter name differs from interface — cosmetic
dotnet_diagnostic.S2139.severity = suggestion   # Log and rethrow — valid pattern in some cases
dotnet_diagnostic.S6667.severity = none         # Logging template placeholders — too strict
dotnet_diagnostic.S125.severity = none          # Commented-out code — we use comments for context
dotnet_diagnostic.S4136.severity = none         # Method overloads order — cosmetic
dotnet_diagnostic.S3358.severity = none         # Nested ternary — readability is case-by-case
dotnet_diagnostic.S2743.severity = none         # Static fields in generic types — valid pattern
dotnet_diagnostic.S1199.severity = none         # Nested code block — lambdas are fine
dotnet_diagnostic.S1172.severity = suggestion   # Unused parameter — flagged but not blocking
dotnet_diagnostic.S1144.severity = suggestion   # Unused private member — flagged but not blocking
dotnet_diagnostic.S1066.severity = none         # Merge if statements — readability preference
dotnet_diagnostic.S1075.severity = error        # Hardcoded URIs — must use config/BrandOptions
dotnet_diagnostic.S2259.severity = error        # Null dereference — ALWAYS block
dotnet_diagnostic.S3928.severity = suggestion   # Exception message should be meaningful
dotnet_diagnostic.S2583.severity = error        # Condition always true/false — logic bug
dotnet_diagnostic.S4158.severity = error        # Empty collection access — runtime crash

# ── Meziantou (MA-rules) ─────────────────────────────────────────────
dotnet_diagnostic.MA0004.severity = none        # ConfigureAwait — not needed in ASP.NET Core
dotnet_diagnostic.MA0002.severity = none        # Dictionary without comparer — too strict
dotnet_diagnostic.MA0021.severity = error       # StringComparer for hash — locale-dependent bug
dotnet_diagnostic.MA0039.severity = none        # Custom cert validation — intentional for Vault dev (suppressed per-file)
dotnet_diagnostic.MA0006.severity = error       # String.Equals with comparison — prevents locale bugs
dotnet_diagnostic.MA0011.severity = none        # IFormatProvider — suppressed globally already
dotnet_diagnostic.MA0015.severity = none        # Constant enum arg
dotnet_diagnostic.MA0016.severity = none        # Prefer return over assignment
dotnet_diagnostic.MA0018.severity = none        # Don't declare static members on generic types
dotnet_diagnostic.MA0026.severity = none        # Fix TODO comments
dotnet_diagnostic.MA0036.severity = none        # Enum suffix
dotnet_diagnostic.MA0046.severity = none        # Sealed class
dotnet_diagnostic.MA0048.severity = none        # File scoped namespace
dotnet_diagnostic.MA0049.severity = none        # Type should be sealed
dotnet_diagnostic.MA0051.severity = none        # Method too long — we'll enable selectively later
dotnet_diagnostic.MA0053.severity = none        # Sealed attribute
dotnet_diagnostic.MA0056.severity = none        # EF Core DbContext ChangeTracker in constructor is safe and required
dotnet_diagnostic.MA0097.severity = none        # Class that implements IComparable
dotnet_diagnostic.MA0134.severity = none        # Observe result of async

# ── AsyncFixer ────────────────────────────────────────────────────────
dotnet_diagnostic.AsyncFixer01.severity = error  # Unnecessary async/await — performance overhead
dotnet_diagnostic.AsyncFixer02.severity = error  # Long-running on threadpool without ConfigureAwait
dotnet_diagnostic.AsyncFixer03.severity = error  # Fire-and-forget async call
dotnet_diagnostic.AsyncFixer04.severity = warning # Fire-and-forget in using block
dotnet_diagnostic.AsyncFixer05.severity = error  # Implicit casting to Task

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Haworks.Notifications.Application</RootNamespace>
    <AssemblyName>Haworks.Notifications.Application</AssemblyName>
    <NoWarn>$(NoWarn);NU1901;NU1902;NU1903;NU1904</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Notifications.Domain/Notifications.Domain.csproj" />
    <ProjectReference Include="../../Contracts/Haworks.Contracts.csproj" />
    <ProjectReference Include="../..\BuildingBlocks\Haworks.BuildingBlocks.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Per .claude/rules/dotnet-clean-arch.md handlers + validators are
         internal sealed; the Unit test project relies on InternalsVisibleTo
         to exercise them. (L3 unblock — added because the L1.G tests landed
         without it and the project no longer compiles otherwise.) -->
    <InternalsVisibleTo Include="Haworks.Notifications.Unit" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MassTransit" />
    <PackageReference Include="MediatR" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="Microsoft.EntityFrameworkCore" />
    <PackageReference Include="Microsoft.Extensions.Configuration.Abstractions" />
    <PackageReference Include="Microsoft.Extensions.Logging.Abstractions" />
    <PackageReference Include="Scriban" />
    <PackageReference Include="Mjml.Net" />
  </ItemGroup>
</Project>

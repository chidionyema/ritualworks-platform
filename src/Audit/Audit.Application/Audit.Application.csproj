<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Haworks.Audit.Application</RootNamespace>
    <AssemblyName>Haworks.Audit.Application</AssemblyName>
    <NoWarn>$(NoWarn);NU1901;NU1902;NU1903;NU1904</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Audit.Domain/Audit.Domain.csproj" />
    <ProjectReference Include="../../Contracts/Haworks.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <!-- Per .claude/rules/dotnet-clean-arch.md handlers + validators are
         internal sealed; the Unit + Integration test projects rely on
         InternalsVisibleTo to exercise them. -->
    <InternalsVisibleTo Include="Haworks.Audit.Unit" />
    <InternalsVisibleTo Include="Haworks.Audit.Integration" />
  </ItemGroup>
  <ItemGroup>
    <!-- Packages every L1 phase will need are pinned here in L0 so
         L1.A/B/C/D never modify the csproj (the parallel-execution
         contract). The four phases share the same BCL + MediatR +
         FluentValidation surface. -->
    <PackageReference Include="AWSSDK.S3" />
    <PackageReference Include="MediatR" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <PackageReference Include="MassTransit" />
  </ItemGroup>
</Project>

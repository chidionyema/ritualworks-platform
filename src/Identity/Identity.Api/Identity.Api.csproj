<Project Sdk="Microsoft.NET.Sdk.Web">
  <ItemGroup>
    <ProjectReference Include="../Identity.Infrastructure/Identity.Infrastructure.csproj" />
    <!--
      OpenTelemetry + Serilog.AspNetCore are transitively brought in by
      Haworks.BuildingBlocks (referenced via Identity.Infrastructure →
      Identity.Application → Identity.Domain → BuildingBlocks). Don't
      re-declare them here — that creates package version conflicts.

      Identity.Api gets the FULL ServiceDefaults stack for free.
    -->
    <PackageReference Include="Swashbuckle.AspNetCore" Version="7.2.0" />
  </ItemGroup>
</Project>

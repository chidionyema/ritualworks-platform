<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Haworks.Catalog.Infrastructure</RootNamespace>
    <AssemblyName>Catalog.Infrastructure</AssemblyName>
    <!-- CA1861: EF Core's generated Migrations files pass new[]{...} as args. Auto-gen, can't edit. -->
    <NoWarn>$(NoWarn);CA1861</NoWarn>
  </PropertyGroup>
  <ItemGroup>
    <ProjectReference Include="../Catalog.Application/Catalog.Application.csproj" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.0" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.0" />
    <PackageReference Include="MassTransit.RabbitMQ" Version="8.3.4" />
  </ItemGroup>
  <ItemGroup>
    <!-- B3: ReservationSweeperService is internal sealed; the catalog
         integration suite drives SweepOnceAsync directly because the
         hosted service is intentionally not registered under the Test
         environment. -->
    <InternalsVisibleTo Include="Haworks.Catalog.Integration" />
  </ItemGroup>
</Project>

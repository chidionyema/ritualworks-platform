<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Haworks.Payments.Application</RootNamespace>
    <AssemblyName>Payments.Application</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="../Payments.Domain/Payments.Domain.csproj" />
    <ProjectReference Include="../../Contracts/Haworks.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MediatR" />
    <PackageReference Include="FluentValidation" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" />
    <!-- Stripe.net types referenced by IStripeClientFactory abstraction. The
         concrete client lives in Payments.Infrastructure; the interface in
         Application needs the Stripe.net types it abstracts. -->
    <PackageReference Include="Stripe.net" />
    <PackageReference Include="VaultSharp" />
    <PackageReference Include="Hangfire.Core" />
    <PackageReference Include="MassTransit" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Haworks.Payments.Unit" />
    <InternalsVisibleTo Include="Haworks.Payments.Integration" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>
</Project>

<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <RootNamespace>Haworks.Payments.Application</RootNamespace>
    <AssemblyName>Payments.Application</AssemblyName>
  </PropertyGroup>
  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
    <ProjectReference Include="../Payments.Domain/Payments.Domain.csproj" />
    <ProjectReference Include="../../Contracts/Haworks.Contracts.csproj" />
  </ItemGroup>
  <ItemGroup>
    <PackageReference Include="MediatR" Version="12.4.1" />
    <PackageReference Include="FluentValidation" Version="11.10.0" />
    <PackageReference Include="FluentValidation.DependencyInjectionExtensions" Version="11.10.0" />
    <!-- Stripe.net types referenced by IStripeClientFactory abstraction. The
         concrete client lives in Payments.Infrastructure; the interface in
         Application needs the Stripe.net types it abstracts. -->
    <PackageReference Include="Stripe.net" Version="44.10.0" />
    <PackageReference Include="VaultSharp" Version="1.17.5" />
    <PackageReference Include="Hangfire.Core" Version="1.8.15" />
    <PackageReference Include="MassTransit" Version="8.3.4" />
  </ItemGroup>

  <ItemGroup>
    <InternalsVisibleTo Include="Haworks.Payments.Unit" />
    <InternalsVisibleTo Include="Haworks.Payments.Integration" />
    <InternalsVisibleTo Include="DynamicProxyGenAssembly2" />
  </ItemGroup>
</Project>

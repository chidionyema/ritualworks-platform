<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <!-- CA1861: EF Core's generated Migrations files pass new[]{...} as args. Auto-gen, can't edit. -->
    <NoWarn>$(NoWarn);CA1861</NoWarn>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="../Content.Application/Content.Application.csproj" />
    <ProjectReference Include="../../BuildingBlocks/Haworks.BuildingBlocks.csproj" />
    <PackageReference Include="Microsoft.EntityFrameworkCore.Design" Version="9.0.0" />
    <PackageReference Include="Npgsql.EntityFrameworkCore.PostgreSQL" Version="9.0.0" />
    <PackageReference Include="AWSSDK.S3" Version="3.7.405.4" />
    <PackageReference Include="SixLabors.ImageSharp" Version="3.1.12" />
  </ItemGroup>

  <ItemGroup>
    <FrameworkReference Include="Microsoft.AspNetCore.App" />
  </ItemGroup>

  <!-- Expose internal SweepOnceAsync to integration tests so the sweeper
       can be invoked directly rather than waiting on its periodic timer. -->
  <ItemGroup>
    <InternalsVisibleTo Include="Content.Integration" />
  </ItemGroup>

</Project>
